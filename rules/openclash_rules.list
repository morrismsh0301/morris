[custom]

; MapleStory 充值
ruleset=🎮 游戏平台,[]DOMAIN-KEYWORD,maplestory
ruleset=🎮 游戏平台,[]DOMAIN-SUFFIX,nexon.com

; YouTube
ruleset=📹 YouTube,[]DOMAIN-SUFFIX,youtube.com
ruleset=📹 YouTube,[]DOMAIN-SUFFIX,googlevideo.com
ruleset=📹 YouTube,[]DOMAIN-SUFFIX,ytimg.com

; Google
ruleset=🍀 Google,[]DOMAIN-SUFFIX,gstatic.com
ruleset=🍀 Google,[]DOMAIN-SUFFIX,googleapis.com
ruleset=🍀 Google,[]DOMAIN-SUFFIX,googleusercontent.com

; ChatGPT
ruleset=🤖 AI,[]DOMAIN-SUFFIX,openai.com
ruleset=🤖 AI,[]DOMAIN-SUFFIX,chatgpt.com
ruleset=🤖 AI,[]DOMAIN-SUFFIX,oaistatic.com

; 国内 CDN（WiFi 不刷图修复）
ruleset=🎯 全球直连,[]DOMAIN-SUFFIX,alicdn.com
ruleset=🎯 全球直连,[]DOMAIN-SUFFIX,taobaocdn.com
ruleset=🎯 全球直连,[]DOMAIN-SUFFIX,bdimg.com
ruleset=🎯 全球直连,[]DOMAIN-SUFFIX,bdstatic.com
ruleset=🎯 全球直连,[]DOMAIN-SUFFIX,zhimg.com
ruleset=🎯 全球直连,[]DOMAIN-SUFFIX,biliimg.com
ruleset=🎯 全球直连,[]DOMAIN-SUFFIX,qpic.cn
ruleset=🎯 全球直连,[]DOMAIN-SUFFIX,gtimg.com
ruleset=🎯 全球直连,[]DOMAIN-SUFFIX,pstatp.com

; 原始规则
ruleset=🤖 AI,https://raw.githubusercontent.com/ACL4SSR/ACL4SSR/master/Clash/Ruleset/AI.list
ruleset=📹 YouTube,https://raw.githubusercontent.com/ACL4SSR/ACL4SSR/master/Clash/Ruleset/YouTube.list
ruleset=🍀 Google,https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Clash/Google/Google.list
ruleset=🎥 Netflix,https://raw.githubusercontent.com/ACL4SSR/ACL4SSR/master/Clash/Ruleset/Netflix.list
ruleset=🎞️ 国内媒体,https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Clash/ChinaMedia/ChinaMedia.list

ruleset=🎯 全球直连,[]GEOSITE,CN
ruleset=🚀 节点选择,[]GEOSITE,geolocation-!cn
ruleset=🎯 全球直连,[]GEOIP,CN
ruleset=🐟 漏网之鱼,[]FINAL
